# ============================================
# TH77 Prime - Environment Variables Template
# ============================================

# Application
APP_NAME=TH77 Prime
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=th77_prime
DB_POOL_MAX=20
DB_POOL_MIN=2

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_32_chars
JWT_REFRESH_EXPIRE=7d

# Session Management
SESSION_SECRET=your_session_secret_key_min_32_chars
SESSION_EXPIRE=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Message Queue (RabbitMQ)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@th77prime.com

# SMS Service
SMS_PROVIDER=twilio
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret

# LINE Messaging API
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_access_token

# Payment Gateway
PAYMENT_PROVIDER=stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Object Storage (MinIO)
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=th77-prime
MINIO_USE_SSL=false

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# OCR Service (Google Vision API)
OCR_ENABLED=false
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# Monitoring & Analytics
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# Frontend URLs
FRONTEND_ADMIN_URL=http://localhost:3001
FRONTEND_AGENT_URL=http://localhost:3002
FRONTEND_MEMBER_URL=http://localhost:3003

# API Documentation
API_DOCS_ENABLED=true
SWAGGER_URL=/api/docs

# System Configuration
SYSTEM_TIMEZONE=Asia/Bangkok
SYSTEM_CURRENCY=THB
MAX_BET_AMOUNT=1000000
MIN_BET_AMOUNT=1
CREDIT_LIMIT_PER_AGENT=100000
COMMISSION_PERCENTAGE=2.5
